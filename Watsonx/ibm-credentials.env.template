# IBM Watson Assistant Credentials Template
# Copy this file to ibm-credentials.env and fill in your actual credentials
# NEVER commit the actual ibm-credentials.env file to Git!

ASSISTANT_APIKEY=your_api_key_here
ASSISTANT_IAM_APIKEY=your_api_key_here
ASSISTANT_URL=https://api.eu-gb.assistant.watson.cloud.ibm.com/instances/your_instance_id_here
ASSISTANT_AUTH_TYPE=iam