[
  {
    "name": "v2-create-booking",
    "displayName": "Create Travel Booking (v2)",
    "url": "http://localhost:8000/api/bookings",
    "integration_type": "REST",
    "request_type": "POST",
    "description": "Create a new travel booking with multiple components (flights, hotels, visa, insurance). Returns booking reference and total cost calculation.",
    "auth_type": "none",
    "auth_value": "",
    "headers": {
      "Content-Type": "application/json",
      "Accept": "application/json"
    },
    "input_schema": {
      "type": "object",
      "properties": {
        "customer_name": {
          "type": "string",
          "description": "Full name of the customer",
          "minLength": 2,
          "maxLength": 100
        },
        "customer_email": {
          "type": "string",
          "format": "email",
          "description": "Customer's email address"
        },
        "travel_date": {
          "type": "string",
          "format": "date-time",
          "description": "Travel date (ISO 8601 format)"
        },
        "destination": {
          "type": "string",
          "description": "Destination location",
          "minLength": 2,
          "maxLength": 100
        },
        "origin": {
          "type": "string",
          "description": "Origin location",
          "minLength": 2,
          "maxLength": 100
        },
        "components": {
          "type": "array",
          "description": "List of booking components (flights, hotels, etc.)",
          "items": {
            "type": "object",
            "properties": {
              "component_type": {
                "type": "string",
                "description": "Type of booking component (flight, hotel, visa, insurance)"
              },
              "provider_name": {
                "type": "string",
                "description": "Service provider name"
              },
              "cost": {
                "type": "number",
                "description": "Component cost in INR",
                "minimum": 0
              },
              "refund_policy": {
                "type": "string",
                "description": "Refund policy details"
              },
              "is_refundable": {
                "type": "boolean",
                "description": "Whether component is refundable",
                "default": false
              },
              "cancellation_fee": {
                "type": "number",
                "description": "Cancellation fee amount",
                "default": 0
              }
            },
            "required": [
              "component_type",
              "provider_name",
              "cost"
            ]
          }
        }
      },
      "required": [
        "customer_name",
        "customer_email",
        "travel_date",
        "destination",
        "origin",
        "components"
      ]
    },
    "jsonpath_filter": "$",
    "tags": [
      "booking",
      "create",
      "travel",
      "refund-estimation"
    ]
  },
