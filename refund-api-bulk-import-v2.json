  {
    "name": "v2-estimate-refund",
    "displayName": "AI Refund Estimation (v2)",
    "url": "http://localhost:8000/api/estimate-refund/{booking_id}",
    "integration_type": "REST",
    "request_type": "POST",
    "description": "Generate AI-powered refund estimate using machine learning models. Considers force majeure events, provider policies, and historical data. Returns expected refund with 95% confidence intervals.",
    "auth_type": "none",
    "auth_value": "",
    "headers": {
      "Content-Type": "application/json",
      "Accept": "application/json"
    },
    "input_schema": {
      "type": "object",
      "properties": {
        "booking_id": {
          "type": "integer",
          "description": "Booking ID to estimate refund for",
          "minimum": 1
        },
        "selected_model": {
          "type": "string",
          "enum": [
            "auto",
            "random_forest",
            "gradient_boosting",
            "rule_based"
          ],
          "description": "ML model to use for estimation",
          "default": "auto"
        },
        "calamity_type": {
          "type": "string",
          "description": "Type of calamity/event (auto for automatic detection)",
          "default": "auto"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ],
          "description": "Severity level of the event",
          "default": "high"
        }
      },
      "required": [
        "booking_id"
      ]
    },
    "jsonpath_filter": "$",
    "tags": [
      "refund",
      "estimation",
      "ai",
      "ml",
      "prediction",
      "refund-estimation"
    ]
  },
